<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Selenium Automation Suite" verbose="1" parallel="methods" thread-count="2">

    <listeners>
        <listener class-name="com.automation.utils.ExtentReportListener"/>
    </listeners>

    <!-- ── Smoke Suite ── -->
    <test name="Smoke Tests">
        <groups>
            <run><include name="smoke"/></run>
        </groups>
        <classes>
            <class name="com.automation.tests.LoginTest"/>
            <class name="com.automation.tests.HomePageTest"/>
            <class name="com.automation.tests.ProductTest"/>
            <class name="com.automation.tests.CheckoutTest"/>
        </classes>
    </test>

    <!-- ── Regression Suite ── -->
    <test name="Regression Tests">
        <groups>
            <run><include name="regression"/></run>
        </groups>
        <classes>
            <class name="com.automation.tests.LoginTest"/>
            <class name="com.automation.tests.HomePageTest"/>
            <class name="com.automation.tests.ProductTest"/>
            <class name="com.automation.tests.CheckoutTest"/>
        </classes>
    </test>

</suite>
